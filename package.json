{
  "name": "simpleoj",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:seed:canonical": "node scripts/seed.js --with-canonical-problems",
    "problems:reset-basic": "node scripts/reset-and-seed-basic-problems.js",
    "problems:cleanup-test": "node scripts/cleanup-test-problems.js",
    "problems:cleanup-test:dry": "node scripts/cleanup-test-problems.js --dry-run",
    "test": "node --test --test-concurrency=1 --test-skip-pattern \"Reset and Seed Basic Problems Script Tests\"",
    "test:reset-basic": "node --test test/reset-basic-problems.test.js",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down",
    "db:local:logs": "docker compose logs -f postgres",
    "db:local:migrate": "node scripts/local-db.js migrate",
    "db:local:seed": "node scripts/local-db.js seed",
    "db:local:reset-basic": "node scripts/local-db.js reset-basic",
    "db:local:test": "node scripts/local-db.js test",
    "dev:local": "node scripts/local-db.js dev",
    "local:setup": "npm run db:local:up && node scripts/ensure-local-databases.js && npm run db:local:migrate",
    "problems:import-api": "node scripts/import-problems-api.js",
    "problems:import-api:dry": "node scripts/import-problems-api.js --dry-run",
    "check:language": "node scripts/check-language-policy.js",
    "scan:cjk": "node scripts/find-cjk-text.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "monaco-editor": "^0.52.2",
    "pg": "^8.16.0",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
